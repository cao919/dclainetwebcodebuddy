# ================================
# 营销AI智能体系统 - 环境变量配置
# ================================

# ======================
# 数据库配置
# ======================
# PostgreSQL连接字符串
DATABASE_URL="postgresql://marketing_ai_user:marketing_ai_password@localhost:5432/marketing_ai_db"

# ======================
# Redis配置
# ======================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD="redis_password"

# ======================
# Auth0 SSO配置
# ======================
# Auth0域名 (例如: your-domain.auth0.com)
AUTH0_DOMAIN="your-domain.auth0.com"

# Auth0客户端ID
AUTH0_CLIENT_ID="your-auth0-client-id"

# Auth0客户端密钥
AUTH0_CLIENT_SECRET="your-auth0-client-secret"

# Auth0 API标识符
AUTH0_AUDIENCE="https://api.marketing-ai.com"

# ======================
# JWT配置
# ======================
# JWT密钥 (生产环境必须修改)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# JWT过期时间 (秒)
JWT_EXPIRES_IN="86400"  # 24小时

# ======================
# 智谱AI配置
# ======================
# 智谱AI API密钥 (从 https://open.bigmodel.cn 获取)
ZHIPU_API_KEY="your-zhipu-ai-api-key-here"

# 智谱AI API基础URL
ZHIPU_API_BASE_URL="https://open.bigmodel.cn/api/paas/v4"

# AI模型配置
ZHIPU_TEXT_MODEL="glm-4"
ZHIPU_IMAGE_MODEL="cogview-3"

# ======================
# 应用配置
# ======================
# 应用环境
NODE_ENV="development"

# 后端服务端口
PORT="3000"

# 前端服务端口
FRONTEND_PORT="5173"

# API基础URL
API_BASE_URL="http://localhost:3000"

# 前端基础URL
FRONTEND_URL="http://localhost:5173"

# ======================
# 文件上传配置
# ======================
# 最大文件大小 (字节)
MAX_FILE_SIZE="10485760"  # 10MB

# 允许的文件类型
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# 上传目录
UPLOAD_DIR="./uploads"

# ======================
# 邮件配置 (可选)
# ======================
# SMTP主机
SMTP_HOST="smtp.gmail.com"

# SMTP端口
SMTP_PORT="587"

# SMTP用户
SMTP_USER="your-email@gmail.com"

# SMTP密码
SMTP_PASSWORD="your-email-password"

# 发件人邮箱
EMAIL_FROM="noreply@marketing-ai.com"

# ======================
# 监控配置
# ======================
# Prometheus端点
PROMETHEUS_ENDPOINT="/metrics"

# Grafana管理员密码
GRAFANA_PASSWORD="admin"

# ======================
# 日志配置
# ======================
# 日志级别
LOG_LEVEL="info"  # error, warn, info, debug

# 日志文件路径
LOG_FILE="./logs/app.log"

# ======================
# 任务队列配置
# ======================
# Bull队列配置
QUEUE_CONCURRENCY="5"
QUEUE_ATTEMPTS="3"
QUEUE_BACKOFF_DELAY="5000"

# ======================
# 安全配置
# ======================
# CORS允许的源
CORS_ORIGIN="http://localhost:5173"

# 速率限制
RATE_LIMIT_WINDOW_MS="900000"  # 15分钟
RATE_LIMIT_MAX_REQUESTS="100"

# ======================
# 功能开关
# ======================
# 启用AI功能
ENABLE_AI_FEATURES="true"

# 启用邮件通知
ENABLE_EMAIL_NOTIFICATIONS="false"

# 启用文件上传
ENABLE_FILE_UPLOAD="true"

# ======================
# 开发工具配置
# ======================
# Prisma Studio端口
PRISMA_STUDIO_PORT="5555"

# Redis Commander端口
REDIS_COMMANDER_PORT="8081"