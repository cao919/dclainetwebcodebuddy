generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex", "fullTextSearch", "views"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model MarketingTask {
  id             String            @id @default(uuid())
  name           String            @db.VarChar(255)
  description    String?           @db.Text
  status         TaskStatus        @default(draft)
  targetAudience Json?
  budget         Decimal?          @db.Decimal(10, 2)
  startDate      DateTime?
  endDate        DateTime?
  createdBy      String            @db.VarChar(100)
  userId         String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  creatives      AdCreative[]      @relation("TaskCreatives")
  user           User?             @relation("UserTasks", fields: [userId], references: [id])
  stages         TaskStageOutput[] @relation("TaskStages")

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([startDate, endDate])
  @@index([userId])
  @@map("marketing_task")
}

model TaskStageOutput {
  id        String        @id @default(uuid())
  taskId    String
  stage     TaskStage
  output    Json
  status    StageStatus   @default(pending)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  task      MarketingTask @relation("TaskStages", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, stage])
  @@index([taskId])
  @@index([stage])
  @@index([status])
  @@map("task_stage_output")
}

model AdCreative {
  id           String                 @id @default(uuid())
  taskId       String
  type         CreativeType
  title        String?                @db.VarChar(255)
  content      Json
  aiGenerated  Boolean                @default(true)
  aiModel      String?                @db.VarChar(100)
  status       CreativeStatus         @default(draft)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  task         MarketingTask          @relation("TaskCreatives", fields: [taskId], references: [id], onDelete: Cascade)
  performances MarketingPerformance[] @relation("CreativePerformances")

  @@index([taskId])
  @@index([type])
  @@index([status])
  @@index([aiGenerated])
  @@index([createdAt])
  @@map("ad_creative")
}

model MarketingPerformance {
  id          String     @id @default(uuid())
  creativeId  String
  metrics     Json
  periodStart DateTime
  periodEnd   DateTime
  source      String?    @db.VarChar(100)
  createdAt   DateTime   @default(now())
  creative    AdCreative @relation("CreativePerformances", fields: [creativeId], references: [id], onDelete: Cascade)

  @@index([creativeId])
  @@index([periodStart, periodEnd])
  @@index([source])
  @@map("marketing_performance")
}

model User {
  id          String          @id @default(uuid())
  auth0Id     String          @unique @db.VarChar(100)
  email       String          @unique @db.VarChar(255)
  name        String?         @db.VarChar(100)
  picture     String?         @db.VarChar(500)
  role        UserRole        @default(user)
  lastLoginAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  auditLogs   AuditLog[]
  tasks       MarketingTask[] @relation("UserTasks")

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?  @db.VarChar(500)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([isPublic])
  @@map("system_config")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   @db.VarChar(100)
  entityType String?  @db.VarChar(100)
  entityId   String?  @db.VarChar(100)
  oldData    Json?
  newData    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

enum TaskStatus {
  draft
  active
  paused
  completed
  failed
  cancelled
}

enum TaskStage {
  data_collection
  market_analysis
  strategy
  planning
  creative
  execution
  analysis
  optimization
}

enum StageStatus {
  pending
  processing
  completed
  failed
  skipped
}

enum CreativeType {
  text
  image
  video
  composite
  carousel
  story
}

enum CreativeStatus {
  draft
  pending
  approved
  rejected
  published
  archived
}

enum UserRole {
  admin
  manager
  marketer
  analyst
  user
  guest
}
