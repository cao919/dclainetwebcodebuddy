{
  "name": "marketing-ai-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/**/*.{vue,ts,js,json,css,scss}",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest",
    "test:e2e": "cypress run",
    "test": "npm run test:unit",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.3.0",
    "vue-router": "^4.2.0",
    "pinia": "^2.1.0",
    "axios": "^1.6.0",
    "element-plus": "^2.3.0",
    "@element-plus/icons-vue": "^2.1.0",
    "echarts": "^5.4.0",
    "vue-echarts": "^6.6.0",
    "@auth0/auth0-vue": "^2.0.0",
    "dayjs": "^1.11.0",
    "lodash-es": "^4.17.0",
    "nprogress": "^0.2.0",
    "screenfull": "^6.0.0",
    "vue-i18n": "^9.0.0",
    "vue-request": "^1.7.0",
    "vuedraggable": "^4.1.0",
    "vue3-clipboard": "^2.0.0",
    "vite-plugin-mock": "^3.0.0",
    "@vueuse/core": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.0.0",
    "@vitejs/plugin-vue-jsx": "^3.0.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^11.0.0",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.0",
    "cypress": "^13.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-vue": "^9.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "sass": "^1.62.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "unplugin-auto-import": "^0.16.0",
    "unplugin-icons": "^0.17.0",
    "unplugin-vue-components": "^0.25.0",
    "vite": "^4.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.0",
    "vite-plugin-svg-icons": "^2.0.0",
    "vitest": "^0.34.0",
    "vue-tsc": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}